# =============================================================================
# DataAgent 环境变量配置示例
# 使用方法：
#   1. 复制本文件：cp .env.example .env
#   2. 将下面的占位符替换为你的真实值
#   3. 不要把 .env 提交到 Git（已在 .gitignore 中忽略）
# =============================================================================

# ---------------------------------------------------------------------------
# 必填：通义千问 DashScope API Key
# 申请地址：https://dashscope.aliyuncs.com/
# ---------------------------------------------------------------------------
DASHSCOPE_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# 可选：模型与接口配置（不填则使用下面的默认值）
# ---------------------------------------------------------------------------
# 聊天模型，可选：qwen-turbo（快） / qwen-plus（均衡）/ qwen-max（强）
# QWEN_CHAT_MODEL=qwen-plus

# Embedding 模型（用于文档向量化）
# QWEN_EMBEDDING_MODEL=text-embedding-v3

# DashScope OpenAI 兼容接口地址（一般无需修改）
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------------------------------------------------------------------------
# 可选：HTTP 超时与重试
# ---------------------------------------------------------------------------
# 单次 API 请求超时时间（秒）
# LLM_TIMEOUT_SECONDS=60

# 超时后最多重试次数（指数退避）
# LLM_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# 可选：RAG 检索参数
# ---------------------------------------------------------------------------
# 文档切块大小（字符数）
# RAG_CHUNK_SIZE=500

# 相邻切块的重叠字符数（保证语义连续性）
# RAG_CHUNK_OVERLAP=50

# 默认返回的检索结果条数
# RAG_TOP_K=10

# 混合检索权重：向量语义占比（其余为 BM25 关键词占比）
# RAG_HYBRID_ALPHA=0.6

# 向量相似度过滤阈值（低于此值的结果会被丢弃）
# RAG_SIMILARITY_THRESHOLD=0.3

# 动态 Top-K 的最小/最大值
# RAG_TOP_K_MIN=3
# RAG_TOP_K_MAX=15

# ---------------------------------------------------------------------------
# 可选：知识库子目录名（与 data/ 下的文件夹名保持一致）
# ---------------------------------------------------------------------------
# KB_DIR_INTERVIEW=数据开发面经
# KB_DIR_LEARNING=学习资料

# ---------------------------------------------------------------------------
# 可选：Agent 工具调用多轮循环（实验性）
# ---------------------------------------------------------------------------
# 开启后使用 OpenAI 原生 tool_calls 协议；默认关闭，使用规则路由
# USE_TOOL_AGENT_LOOP=false

# 工具调用最大循环步数
# AGENT_TOOL_LOOP_MAX_STEPS=8

# ---------------------------------------------------------------------------
# 可选：调试选项
# ---------------------------------------------------------------------------
# 是否将上传的简历/JD 持久化到磁盘（默认不落盘，保护用户隐私）
# PERSIST_UPLOADS_TO_DISK=false
